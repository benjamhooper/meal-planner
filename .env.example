# Copy this file to .env and fill in values before running

# ── Database ──────────────────────────────────────────────
# Local dev (Docker Compose Postgres)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=mealplanner;Username=postgres;Password=postgres

# ── JWT ───────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
Jwt__Secret=CHANGE_ME_use_a_long_random_string_at_least_32_chars

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
AllowedOrigins__0=http://localhost:3000

# ── Frontend (.env.local in web/) ─────────────────────────
# URL of the API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
