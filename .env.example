# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every value before running docker compose.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
# The subdomain pointing at this machine (e.g. meals.yourdomain.com).
# Used by the API for CORS and OAuth redirects.
DOMAIN=meals.yourdomain.com

# Local network IP of this machine — used to allow CORS from LAN access.
# Find it with: ip route get 1 | awk '{print $7; exit}'
LAN_IP=192.168.1.x

# ── SQL Server ────────────────────────────────────────────────────────────────
# At least 8 chars, mixed case, digit, and symbol.
MSSQL_SA_PASSWORD=YourStr0ng!Password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

# ── Google OAuth (optional — leave blank to disable) ─────────────────────────
# Authorized redirect URI to add in Google Cloud Console:
#   https://meals.yourdomain.com/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth (optional — leave blank to disable) ─────────────────────────
# Authorized callback URL to add in GitHub Developer Settings:
#   https://meals.yourdomain.com/api/v1/auth/github/callback
GH_CLIENT_ID=
GH_CLIENT_SECRET=

