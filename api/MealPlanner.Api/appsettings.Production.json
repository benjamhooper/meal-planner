{
  "ConnectionStrings": {
    "DefaultConnection": "@Microsoft.KeyVault(SecretUri=https://VAULT_NAME.vault.azure.net/secrets/DbConnectionString/)"
  },
  "Jwt": {
    "Secret": "@Microsoft.KeyVault(SecretUri=https://VAULT_NAME.vault.azure.net/secrets/JwtSecret/)"
  },
  "Google": {
    "ClientId": "@Microsoft.KeyVault(SecretUri=https://VAULT_NAME.vault.azure.net/secrets/GoogleClientId/)",
    "ClientSecret": "@Microsoft.KeyVault(SecretUri=https://VAULT_NAME.vault.azure.net/secrets/GoogleClientSecret/)"
  },
  "GitHub": {
    "ClientId": "@Microsoft.KeyVault(SecretUri=https://VAULT_NAME.vault.azure.net/secrets/GitHubClientId/)",
    "ClientSecret": "@Microsoft.KeyVault(SecretUri=https://VAULT_NAME.vault.azure.net/secrets/GitHubClientSecret/)"
  },
  "FrontendUrl": "https://YOUR_SWA_DOMAIN.azurestaticapps.net",
  "AllowedOrigins": [
    "https://YOUR_SWA_DOMAIN.azurestaticapps.net"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  }
}